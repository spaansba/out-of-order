{
  "name": "focuspocus-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Focus & keyboard-accessibility validation for real browsers",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "dev": "pnpm --parallel --filter @focuspocus/core --filter @focuspocus/reveal run dev",
    "typecheck": "pnpm -r --filter \"./packages/**\" run typecheck",
    "test": "pnpm -r --filter \"./packages/**\" run test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.7.0"
}
