{
  "name": "@out-of-order/vitest",
  "version": "0.1.2",
  "description": "toHaveValidTabOrder() matcher for Vitest Browser Mode.",
  "keywords": [
    "a11y",
    "accessibility",
    "browser",
    "matcher",
    "tab-order",
    "vitest"
  ],
  "homepage": "https://github.com/spaansba/out-of-order#readme",
  "bugs": "https://github.com/spaansba/out-of-order/issues",
  "license": "MIT",
  "author": "Bart Spaans",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spaansba/out-of-order.git",
    "directory": "packages/vitest"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@out-of-order/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/browser": "^2.1.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.47.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  }
}
