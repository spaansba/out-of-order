{
  "name": "@out-of-order/vitest",
  "version": "0.1.0",
  "description": "toHaveValidTabOrder() matcher for Vitest Browser Mode.",
  "keywords": [
    "a11y",
    "accessibility",
    "browser",
    "matcher",
    "tab-order",
    "vitest"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@out-of-order/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/browser": "^2.1.0",
    "playwright": "^1.47.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  }
}
