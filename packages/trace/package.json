{
  "name": "@out-of-order/trace",
  "version": "0.5.0",
  "description": "Drop a visual overlay on any page: numbered tab stops, the path between them, and a11y findings ringed in place.",
  "keywords": [
    "a11y",
    "accessibility",
    "focus",
    "overlay",
    "tab-order",
    "visualizer"
  ],
  "homepage": "https://github.com/spaansba/out-of-order#readme",
  "bugs": "https://github.com/spaansba/out-of-order/issues",
  "license": "MIT",
  "author": "Bart Spaans",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spaansba/out-of-order.git",
    "directory": "packages/trace"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@out-of-order/core": "workspace:*",
    "dom-accessibility-api": "^0.7.1"
  },
  "devDependencies": {
    "@vitest/browser": "^2.1.0",
    "playwright": "^1.47.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
